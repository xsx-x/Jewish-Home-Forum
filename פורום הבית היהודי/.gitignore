# Dependencies - תיקיית הספריות (היא כבדה מדי ואין טעם להעלות אותה)
node_modules/

# Production - תיקיית האתר המוכן (היא נוצרת אוטומטית בכל בנייה)
dist/

# Secrets - קבצי הסיסמאות והגדרות הסביבה (חשוב ביותר!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs - קבצי שגיאות ויומני הרצה
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files - קבצי מערכת של המחשב
.DS_Store
Thumbs.db
